                }
            }
            
            if(this.btn && this.btn.material.emissive) this.btn.material.emissiveIntensity = 0;

            if (!karen.active && !karen.isSpawning) {
                if (currentLevel === 11) {
                    // Level 11: 100% kans dat beide naar buiten komen
                    karen.triggerSpawnCountdown();
                    if (!bozeman) bozeman = new EnemyNPC('bozeman', currentLevel);
                    bozeman.triggerSpawnCountdown();
                } 
                else {
                    // 60% kans op Karen, exact 20% kans op Boze Man in de rest van de levels
                    let karenKomt = Math.random() < 0.60 || currentLevel >= 5;
                    let bozemanKomt = Math.random() < 0.20;
                    
                    if (karenKomt) karen.triggerSpawnCountdown();
                    
                    if (bozemanKomt) {
                        if (!bozeman) bozeman = new EnemyNPC('bozeman', currentLevel);
                        bozeman.triggerSpawnCountdown();
                    }
                    
                    if (!karenKomt && !bozemanKomt) {
                        successAlert.innerText = "Ze hebben niks door... 😎";
                        successAlert.classList.remove('hidden');
                        setTimeout(() => {
                            successAlert.classList.add('hidden');
                            spawnExitPortal("Kust is veilig! Naar de volgende straat! 🚶");
                        }, 3000);
                    }
                }
            }
        }
    }

