    window.onload = function() {
        initThreeJS();
        
        function animate() {
            requestAnimationFrame(animate);
            const dt = clock.getDelta();
            
            if (gameState === 'PLAY') {
                player.update(dt);
                if (mischiefItem) mischiefItem.update(dt);

                if (exitPortal) {
                    exitPortal.update(dt); 
                    if (player.mesh.position.distanceTo(exitPortal.mesh.position) < (player.radius + exitPortal.radius)) {
                        if (currentLevel < maxLevel) initLevel(currentLevel + 1);
                        else winGame();
                    }
                }

                if (karen.active) {
                    karen.update(dt, player);
                    if (!player.isHiddenFromKaren && player.mesh.position.distanceTo(karen.mesh.position) < (player.radius + karen.radius)) {
                        triggerGameOver();
                    }
                }

                if (bozeman && bozeman.active) {
                    bozeman.update(dt, player);
                    if (!player.isHiddenFromBozeMan && player.mesh.position.distanceTo(bozeman.mesh.position) < (player.radius + bozeman.radius)) {
                        triggerGameOver();
                    }
                }
            } 
            else if (gameState === 'CUTSCENE') {
                cutsceneTime += dt;
                
                // Camera zoomt iets in op de actie met een vaste afstand
                const cutsceneCamDist = 40;
                const targetX = player.mesh.position.x + cutsceneCamDist * Math.sin(camAngleX) * Math.cos(camAngleY);
                const targetY = player.mesh.position.y + cutsceneCamDist * Math.sin(camAngleY);
                const targetZ = player.mesh.position.z + cutsceneCamDist * Math.cos(camAngleX) * Math.cos(camAngleY);
                camera.position.lerp(new THREE.Vector3(targetX, Math.max(10, targetY), targetZ), 0.1);
                camera.lookAt(mischiefItem.mesh.position); // Kijk naar het voorwerp

                // Animaties afhankelijk van het voorwerp
                if (mischiefItem.type === 'trash') {
                    // Karatetrap!
                    player.model.legR.rotation.x = -Math.PI / 3;
                } 
                else if (mischiefItem.type === 'stone') {
                    // Gooien
                    player.model.armR.rotation.x = Math.sin(cutsceneTime * Math.PI) * Math.PI; 
                    if (cutsceneTime > 0.5 && mischiefItem.stoneMesh) {
                        mischiefItem.stoneMesh.position.lerp(new THREE.Vector3(0, 11, -9.9), 0.15); // Vliegt naar raam
                    }
                } 
                else {
                    // Reiken / Uithalen
                    player.model.armR.rotation.x = -Math.PI / 2;
                }

                // Na 1.5 seconden is de actie klaar
                if (cutsceneTime > 1.5) {
                    mischiefItem.complete();
                    gameState = 'PLAY';
                    cutsceneTime = 0;
                    player.model.armR.rotation.x = 0;
                    player.model.legR.rotation.x = 0;
                }
            }

            renderer.render(scene, camera);
        }
        
        animate();
    };
</script>
</body>
</html>
